# ==========================================================================
#  Moloni -> ntfy : configuracao
#  Copia este ficheiro para ".env" e preenche os valores.
#  NUNCA partilhes o .env nem o commits para o git (ja esta no .gitignore).
# ==========================================================================

# --- Moloni (classico, API v1) --------------------------------------------
# Obtem o Developer ID (client_id) e o Client Secret no portal de developer
# do Moloni: https://www.moloni.pt/dev/
MOLONI_CLIENT_ID=
MOLONI_CLIENT_SECRET=
# Email e password com que entras no Moloni.
MOLONI_USERNAME=
MOLONI_PASSWORD=
# Opcional: se a conta tiver varias empresas, fixa aqui o id.
# Se ficar vazio, usa a primeira empresa (e mostra todas nos logs).
MOLONI_COMPANY_ID=

# --- O que conta como "venda em loja" (tudo opcional) ---------------------
# Corre "python moloni_ntfy.py list-types" para descobrires estes valores.
# Se deixares tudo vazio, notifica TODOS os documentos novos.
MOLONI_DOCUMENT_SET_ID=
MOLONI_DOCUMENT_TYPE_ID=
# Estado do documento. 1 = so documentos fechados/emitidos (recomendado).
# Deixa vazio para nao filtrar por estado.
MOLONI_STATUS=1
# Dias para tras a verificar em cada ciclo. 0 = so hoje; 1 = hoje + ontem.
MOLONI_LOOKBACK_DAYS=1

# --- ntfy ------------------------------------------------------------------
NTFY_SERVER=https://ntfy.sh
# Escolhe um topico SECRETO e unico (qualquer pessoa que saiba o nome ve as
# notificacoes). Ex.: moloni-loja-a8f3k9z2qx
NTFY_TOPIC=
# Opcional: token Bearer, se usares um topico/servidor protegido.
NTFY_TOKEN=
# min | low | default | high | urgent
NTFY_PRIORITY=high

# --- Geral -----------------------------------------------------------------
POLL_INTERVAL_SECONDS=120
STATE_FILE=./data/state.json
LOG_LEVEL=INFO
